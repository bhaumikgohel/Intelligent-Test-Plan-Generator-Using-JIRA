# Server Configuration
PORT=3001

# Encryption Key (generate a strong random key for production)
ENCRYPTION_KEY=your-secret-encryption-key-here

# Database Configuration
# Options: 'sqlite' or 'postgres'
DB_TYPE=sqlite

# PostgreSQL Connection URL (required when DB_TYPE=postgres)
# Example: postgres://username:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/testplan_generator

# JIRA Configuration (optional - can be set via UI)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_API_TOKEN=your-jira-api-token
JIRA_USERNAME=your-email@example.com

# Groq Configuration (optional - can be set via UI)
GROQ_API_KEY=your-groq-api-key

# Ollama Configuration (optional - can be set via UI)
OLLAMA_BASE_URL=http://localhost:11434
